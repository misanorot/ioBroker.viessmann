{
  "compileOnSave": true,
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "sourceMap": false,
    "inlineSourceMap": false,
    "skipLibCheck": true,
    "target": "ES2022",
    "outDir": "./build"
  },
  "include": [
    "**/*.js",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules/**",
    "test/**",
    "admin/**"
  ]
}
